/*
 * DiRT v2 Nextflow configuration.
 * Works with any plant genome from EnsemblPlants and any paired-end Illumina
 * RNA-seq dataset.
 */

manifest {
    name            = 'DiRTv2'
    description     = 'Dicistronic Transcript detection from paired-end Illumina RNA-seq.'
    author          = 'Fei Zheng'
    version         = '2.0.0'
    nextflowVersion = '>=23.04.0'
}

params {
    // ---- Required inputs (override on CLI) --------------------------------
    samplesheet  = null   // CSV: sample,fastq_1,fastq_2
    genome       = null   // reference FASTA (any plant)
    gff          = null   // GFF3 annotation (e.g. EnsemblPlants)

    // ---- Optional --------------------------------------------------------
    hisat2_index = null   // prebuilt HISAT2 index prefix; otherwise built from genome

    // ---- Output -----------------------------------------------------------
    outdir       = 'results'
    tracedir     = "${params.outdir}/pipeline_info"

    // ---- Resource tuning --------------------------------------------------
    cpus            = 8
    memory          = '32 GB'
    min_length      = 100
    bam_mem_per_th  = '1G'

    // ---- DiRT v2 R analysis ----------------------------------------------
    min_count       = 1     // min read count in EVERY sample to call a tRNA/gene expressed
    fdr_threshold   = 0.05  // FDR cutoff for the paired t-tests (e.g. 0.01, 0.05, 0.1)
}

// --------------------------------------------------------------------------
// Execution profiles
// --------------------------------------------------------------------------
profiles {

    standard {
        process.executor = 'local'
    }

    conda {
        conda.enabled       = true
        process.conda       = "${projectDir}/conf/environment.yml"
    }

    docker {
        docker.enabled      = true
        process.container   = 'quay.io/biocontainers/mulled-v2-dirtv2:latest'
    }

    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
    }

    slurm {
        process.executor    = 'slurm'
        process.queue       = 'compute'
    }

    test {
        params.samplesheet  = "${projectDir}/assets/samples.csv"
        params.outdir       = 'results_test'
    }
}

// --------------------------------------------------------------------------
// Per-process resources
// --------------------------------------------------------------------------
process {
    cpus   = { params.cpus   }
    memory = { params.memory }
    errorStrategy = 'retry'
    maxRetries    = 1

    withName: 'HISAT2_BUILD' {
        cpus   = { Math.max(params.cpus, 8) }
        memory = { '32 GB' }
    }
    withName: 'HISAT2_ALIGN' {
        cpus   = { Math.max(params.cpus, 8) }
        memory = { '24 GB' }
    }
    withName: 'DIRTV2_ANALYSIS' {
        cpus   = { 4 }
        memory = { '16 GB' }
    }
}

// --------------------------------------------------------------------------
// Reporting
// --------------------------------------------------------------------------
report   { enabled = true; file = "${params.tracedir}/execution_report.html" }
timeline { enabled = true; file = "${params.tracedir}/execution_timeline.html" }
trace    { enabled = true; file = "${params.tracedir}/execution_trace.txt" }
dag      { enabled = true; file = "${params.tracedir}/pipeline_dag.svg" }
